# ─── AlharisTech Platform — Environment Variables ────────────────────────────
# Copy to .env and adjust for your local environment
#   cp .env.example .env
#
# Required vars are uncommented with safe dev defaults.
# Optional/future vars are commented out.

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=alharistech
DB_USER=postgres
DB_PASSWORD=postgres

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_USERNAME=
# REDIS_DB=0

# ─── JWT — Generate production secrets with: openssl rand -hex 64 ────────────
JWT_SECRET=dev-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=*

# ─── Event Queue ─────────────────────────────────────────────────────────────
EVENT_QUEUE_PREFIX=aht
EVENT_QUEUE_ATTEMPTS=5
EVENT_QUEUE_BACKOFF_MS=2000

# ─── Contract Validation ─────────────────────────────────────────────────────
CONTRACT_RESPONSE_MODE=lenient

# ─── S3 / MinIO (future) ────────────────────────────────────────────────────
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=alharistech
# S3_REGION=us-east-1

# ─── Email / SMTP (future) ───────────────────────────────────────────────────
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=

# ─── SMS (future) ───────────────────────────────────────────────────────────
# SMS_PROVIDER=twilio
# SMS_API_KEY=
# SMS_SENDER_ID=AlharisTech

# ─── Payment (future) ───────────────────────────────────────────────────────
# PAYMENT_GATEWAY=stripe
# PAYMENT_API_KEY=
# PAYMENT_WEBHOOK_SECRET=

# ─── Monitoring (future) ────────────────────────────────────────────────────
# SENTRY_DSN=
# OPEN_TELEMETRY_ENDPOINT=

# ─── Connection Strings (alternative to individual DB/Redis fields) ──────────
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/alharistech
# REDIS_URL=redis://redis:6379
