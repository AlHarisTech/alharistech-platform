# Auto detect text files and perform LF normalization
* text=auto

# Markdown
*.md text eol=lf

# YAML
*.yaml text eol=lf
*.yml text eol=lf

# PlantUML
*.puml text eol=lf

# Shell scripts
*.sh text eol=lf

# TypeScript/JavaScript (future)
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
